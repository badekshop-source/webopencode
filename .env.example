# badekshop - Environment Variables Template
# Copy this file to .env.local and fill in the values

# ============================================
# Database (Neon PostgreSQL)
# ============================================
DATABASE_URL="postgresql://user:password@hostname/dbname?sslmode=require"

# ============================================
# Authentication (better-auth)
# ============================================
BETTER_AUTH_SECRET="generate-a-random-secret-key-here"
BETTER_AUTH_URL="http://localhost:3000"

# ============================================
# Midtrans Payments
# ============================================
# Get keys from: https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxxxxxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxxxxxx"
MIDTRANS_MODE="sandbox"

# ============================================
# Cloudinary Storage
# ============================================
# Get keys from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================
# Email Service (Resend)
# ============================================
# Get key from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxx"

# ============================================
# Application
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================
# Cron Jobs (for automated tasks)
# ============================================
# Generate a random secret: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# ============================================
# Rate Limiting (Optional - Vercel KV/Upstash)
# ============================================
# Only needed if using Upstash for distributed rate limiting
# Otherwise, in-memory rate limiting is used as fallback
KV_URL=""
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
